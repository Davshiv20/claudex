#!/usr/bin/env bash
set -uo pipefail

INSTALL_DIR="__CLAUDEX_INSTALL_DIR__"
CONFIG_DIR="__CLIPROXY_CONFIG_DIR__"
CONFIG_FILE="__CLIPROXY_CONFIG_FILE__"
API_KEY_FILE="$INSTALL_DIR/api-key"
MODELS_CONF="$INSTALL_DIR/models.conf"
BASE_URL="${ANTHROPIC_BASE_URL:-http://127.0.0.1:8317}"

problems=0
ok()   { printf '  \033[1;32m✓\033[0m %s\n' "$*"; }
warn() { printf '  \033[1;33m!\033[0m %s\n' "$*"; }
bad()  { printf '  \033[1;31m✗\033[0m %s\n' "$*"; problems=$((problems + 1)); }

echo "claudex doctor"
echo ""

echo "Dependencies:"
command -v claude   >/dev/null 2>&1 && ok "claude (Claude Code) found" || bad "claude not found — install Claude Code"
command -v python3  >/dev/null 2>&1 && ok "python3 found" || bad "python3 not found"
command -v curl     >/dev/null 2>&1 && ok "curl found" || bad "curl not found"
if command -v cliproxyapi >/dev/null 2>&1 || command -v cli-proxy-api >/dev/null 2>&1 || [[ -x "$INSTALL_DIR/bin/cli-proxy-api" ]]; then
  ok "CLIProxyAPI binary found"
else
  bad "CLIProxyAPI binary not found — run install.sh"
fi
command -v fzf >/dev/null 2>&1 && ok "fzf found (fuzzy model picker enabled)" || warn "fzf not found (picker falls back to a numbered menu)"

echo ""
echo "Files & permissions:"
check_perm() {
  local f="$1" want="600"
  if [[ ! -e "$f" ]]; then bad "missing: $f"; return; fi
  local mode
  mode="$(stat -f '%Lp' "$f" 2>/dev/null || stat -c '%a' "$f" 2>/dev/null)"
  if [[ "$mode" == "$want" ]]; then ok "$f ($mode)"; else warn "$f has mode $mode (expected $want)"; fi
}
check_perm "$API_KEY_FILE"
check_perm "$CONFIG_FILE"
[[ -f "$MODELS_CONF" ]] && ok "models.conf present" || warn "models.conf missing — run install.sh"

echo ""
echo "Authentication:"
if [[ -d "$CONFIG_DIR" ]] && find "$CONFIG_DIR" -maxdepth 2 -type f -name '*.json' 2>/dev/null | grep -q .; then
  ok "OAuth/token files present in $CONFIG_DIR"
else
  warn "no auth files found — run: claudex-auth codex"
fi

echo ""
echo "Proxy:"
if [[ -f "$API_KEY_FILE" ]]; then
  key="$(cat "$API_KEY_FILE")"
  if curl --connect-timeout 5 --max-time 15 -fsS "$BASE_URL/v1/models" -H "Authorization: Bearer $key" >/dev/null 2>&1; then
    ok "proxy reachable at $BASE_URL"
  else
    bad "proxy not reachable at $BASE_URL — run: claudex-proxy start"
  fi
else
  bad "no api-key file — run install.sh"
fi

echo ""
echo "Model map:"
if [[ -f "$MODELS_CONF" ]]; then
  for slot in OPUS SONNET HAIKU; do
    line="$(grep -E "^[[:space:]]*$slot[[:space:]]*=" "$MODELS_CONF" 2>/dev/null | tail -1)"
    val="${line#*=}"; val="${val#"${val%%[![:space:]]*}"}"
    printf '  %-7s -> %s\n' "$slot" "${val:-<unset>}"
  done
fi

echo ""
if [[ "$problems" -eq 0 ]]; then
  printf '\033[1;32mAll critical checks passed.\033[0m\n'
  exit 0
else
  printf '\033[1;31m%d problem(s) found.\033[0m See messages above.\n' "$problems"
  exit 1
fi
