#!/usr/bin/env bash
set -euo pipefail

CONFIG_FILE="__CLIPROXY_CONFIG_FILE__"
LOG_DIR="$HOME/.cli-proxy-api/logs"
PID_FILE="$HOME/.cli-proxy-api/claudex-proxy.pid"

cliproxy_bin() {
  if command -v cliproxyapi >/dev/null 2>&1; then echo cliproxyapi; return; fi
  if command -v cli-proxy-api >/dev/null 2>&1; then echo cli-proxy-api; return; fi
  if [[ -x "__CLAUDEX_INSTALL_DIR__/bin/cli-proxy-api" ]]; then echo "__CLAUDEX_INSTALL_DIR__/bin/cli-proxy-api"; return; fi
  echo "CLIProxyAPI not found. Run install.sh first." >&2
  exit 1
}

is_running() {
  [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" >/dev/null 2>&1
}

case "${1:-status}" in
  start)
    mkdir -p "$LOG_DIR"
    if is_running; then
      echo "CLIProxyAPI already running (pid $(cat "$PID_FILE"))"
      exit 0
    fi
    nohup "$(cliproxy_bin)" -config "$CONFIG_FILE" > "$LOG_DIR/stdout.log" 2> "$LOG_DIR/stderr.log" &
    echo $! > "$PID_FILE"
    sleep 1
    if is_running; then
      echo "Started CLIProxyAPI on http://127.0.0.1:8317 (pid $(cat "$PID_FILE"))"
    else
      echo "Failed to start. See $LOG_DIR/stderr.log" >&2
      exit 1
    fi
    ;;
  stop)
    if is_running; then
      kill "$(cat "$PID_FILE")"
      rm -f "$PID_FILE"
      echo "Stopped CLIProxyAPI"
    else
      echo "CLIProxyAPI is not running"
    fi
    ;;
  restart)
    "$0" stop || true
    "$0" start
    ;;
  status)
    if is_running; then
      echo "running (pid $(cat "$PID_FILE"))"
    else
      echo "stopped"
    fi
    ;;
  logs)
    tail -f "$LOG_DIR/stdout.log" "$LOG_DIR/stderr.log"
    ;;
  models)
    key="$(cat "__CLAUDEX_INSTALL_DIR__/api-key")"
    curl -fsS http://127.0.0.1:8317/v1/models -H "Authorization: Bearer $key" | python3 -m json.tool
    ;;
  *)
    echo "Usage: claudex-proxy <start|stop|restart|status|logs|models>" >&2
    exit 1
    ;;
esac
